# Proxmox provider
PROXMOX_API_URL=https://10.0.0.2:8006
PROXMOX_TOKEN_ID=openvdi@pve!openvdi
PROXMOX_TOKEN_SECRET=your-token-secret-here
PROXMOX_VERIFY_SSL=false

# Node + VM defaults used by the Milestone 1 acceptance test
PROXMOX_DEFAULT_NODE=pia-dev
PROXMOX_TEMPLATE_VMID=9001
PROXMOX_TEST_VMID=9999
PROXMOX_TARGET_STORAGE=

# --- Postgres ---
POSTGRES_USER=openvdi
POSTGRES_PASSWORD=openvdi
POSTGRES_DB=openvdi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- pgAdmin ---
# Use a real TLD — pgAdmin rejects .local and other RFC 2606 reserved domains.
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# --- Encryption ---
# Generate once per deployment: `python -m app.crypto generate-key`
# Do NOT commit the generated key. Losing it means losing all stored
# cluster credentials — they can't be recovered, only re-entered.
OPENVDI_ENCRYPTION_KEY=

# --- M4 Auth mode ---
# 'jwt' is production. 'dev' retains the M2/M3 X-Dev-* header path
# for local development. The broker REFUSES to start in dev mode
# unless this is set explicitly to 'dev'. See docs/api-design.md.
OPENVDI_AUTH_MODE=jwt

# --- M4 JWT (jwt mode only) ---
# HS256 signing key. Must be ≥32 bytes. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# All broker instances in a multi-broker deployment share this value.
OPENVDI_JWT_SECRET=

# --- M4 LDAP / AD (jwt mode only) ---
# Service account for the broker's LDAP queries. The broker binds as
# this account, searches for the user, then rebinds as the user to
# verify their password. Pure-LDAP installs override the filter
# defaults to match their schema.
OPENVDI_LDAP_URL=ldaps://dc1.example.com:636
OPENVDI_LDAP_BIND_DN=CN=openvdi-svc,OU=ServiceAccounts,DC=example,DC=com
OPENVDI_LDAP_BIND_PASSWORD=
OPENVDI_LDAP_USER_BASE=OU=Users,DC=example,DC=com
OPENVDI_LDAP_GROUP_BASE=OU=Groups,DC=example,DC=com
# Filter templates. {username} and {user_dn} are the supported
# placeholders. Defaults match Active Directory. For pure LDAP,
# typical override:  OPENVDI_LDAP_USER_FILTER=(uid={username})
OPENVDI_LDAP_USER_FILTER=(sAMAccountName={username})
OPENVDI_LDAP_GROUP_FILTER=(member={user_dn})
# Group whose members are granted admin role in OpenVDI.
OPENVDI_LDAP_ADMIN_GROUP=OpenVDI-Admins
# TLS verification. Set to false ONLY for self-signed AD CAs in
# dev/test. Production MUST be true with a proper CA chain.
OPENVDI_LDAP_VERIFY_SSL=true

# --- M4 Portal origin (jwt mode only) ---
# Single origin where the portal is served from. Required for the
# SameSite=Strict refresh-token cookie. See docs/deploy.md →
# Same-Origin Requirement.
OPENVDI_PORTAL_ORIGIN=

# --- M4 Logging ---
# 'text' is dev-friendly; 'json' is production-recommended for
# log-aggregator ingestion. M4-12 wires the JSON formatter swap.
OPENVDI_LOG_FORMAT=text
OPENVDI_LOG_LEVEL=INFO
OPENVDI_LOG_LEVEL_HTTPX=WARNING

# --- M4 Audit retention ---
# audit_retention worker (M4-13) prunes audit_log rows older than this.
OPENVDI_AUDIT_RETENTION_DAYS=90

# --- e2e admin smoke test (M4-25) ---
# These are needed by `portal/e2e/admin-flow.spec.ts`. The admin user
# must be a member of OPENVDI_LDAP_ADMIN_GROUP. Both users must exist
# in the LDAP/AD realm the broker is bound to. Absent vars → spec
# auto-skips.
OPENVDI_TEST_ADMIN_USER=
OPENVDI_TEST_ADMIN_PASSWORD=
OPENVDI_TEST_USER_PASSWORD=
# Optional overrides (defaults: e2e-cluster / e2e-template / 9000)
# OPENVDI_TEST_CLUSTER_NAME=
# OPENVDI_TEST_TEMPLATE_NAME=
# OPENVDI_TEST_VMID_RANGE_START=

# --- M5 openvdi-admin MCP server ---
# Required: where the broker is reachable from the MCP host. Should
# be the same origin the portal uses (per docs/deploy.md →
# Same-Origin Requirement) so the broker's JWT + refresh-cookie work.
OPENVDI_BROKER_URL=https://openvdi.local
# AD account the MCP authenticates as. Must be a member of the
# admin group the broker recognizes (OPENVDI_LDAP_ADMIN_GROUP above).
OPENVDI_SERVICE_USER=
OPENVDI_SERVICE_PASSWORD=
# True (default) verifies the broker's TLS cert. Set False only for
# self-signed dev clusters.
OPENVDI_VERIFY_SSL=true
# When true, destructive tools refuse to execute (per S1). Useful
# for read-only diagnosis deployments.
OPENVDI_MCP_READ_ONLY=false
# 'text' for dev, 'json' for production / log aggregators.
OPENVDI_MCP_LOG_FORMAT=text
OPENVDI_MCP_LOG_LEVEL=INFO
# When true, emit a "tool started" log line in addition to the
# "tool completed" line. Doubles log volume; default false. Flip
# to true when debugging tool hangs.
OPENVDI_MCP_LOG_TOOL_STARTS=false
