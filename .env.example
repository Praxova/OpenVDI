# Proxmox VE
PVE_API_URL=https://10.0.0.2:8006
PVE_TOKEN_ID=openvdi@pve!openvdi
PVE_TOKEN_SECRET=your-token-secret-here
PVE_VERIFY_SSL=false

# Database
DB_URL=postgresql+asyncpg://openvdi:openvdi@localhost:5434/openvdi

# Broker
BROKER_HOST=0.0.0.0
BROKER_PORT=8080
LOG_LEVEL=INFO

# Proxmox defaults
DEFAULT_NODE=pis-dev
DEFAULT_TEMPLATE_VMID=9001
CLONE_TIMEOUT=300
TASK_POLL_INTERVAL=1.0
