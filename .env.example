# Proxmox provider
PROXMOX_API_URL=https://10.0.0.2:8006
PROXMOX_TOKEN_ID=openvdi@pve!openvdi
PROXMOX_TOKEN_SECRET=your-token-secret-here
PROXMOX_VERIFY_SSL=false

# Node + VM defaults used by the Milestone 1 acceptance test
PROXMOX_DEFAULT_NODE=pia-dev
PROXMOX_TEMPLATE_VMID=9001
PROXMOX_TEST_VMID=9999
PROXMOX_TARGET_STORAGE=

