# Broker connection.
# Same scheme/host the portal uses — must include the protocol.
OPENVDI_BROKER_URL=https://openvdi.example.com

# Service account credentials. The user must be a member of
# OPENVDI_LDAP_ADMIN_GROUP on the broker side. Per A1: this is a
# regular AD user, not a special "service account" type.
OPENVDI_SERVICE_USER=openvdi-mcp-svc
OPENVDI_SERVICE_PASSWORD=replace-me

# TLS verification. Default true; set false ONLY for self-signed
# clusters in dev. Production deployments MUST verify.
OPENVDI_VERIFY_SSL=true

# Read-only mode. When true, every destructive tool returns a
# structured error instead of executing. Default false. Tools
# enforce this in M5-03+ — the auth/client layer is unaffected.
OPENVDI_MCP_READ_ONLY=false

# Log format. text (dev default) or json (production). Defaults to text.
OPENVDI_MCP_LOG_FORMAT=text

# Optional: log level. Defaults to INFO.
OPENVDI_MCP_LOG_LEVEL=INFO
