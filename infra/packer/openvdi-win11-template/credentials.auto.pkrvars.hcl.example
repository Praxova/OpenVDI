// Copy this file to credentials.auto.pkrvars.hcl and fill in the values.
// The .auto.pkrvars.hcl extension means Packer auto-loads it — no -var-file flag.
// credentials.auto.pkrvars.hcl is in .gitignore. Do NOT commit secrets.

proxmox_url      = "https://10.0.0.2:8006/api2/json"
proxmox_username = "tofu@pve!automation"
proxmox_token    = "PASTE-YOUR-API-TOKEN-UUID-HERE"
proxmox_node     = "pia-dev"

// Build-time WinRM password. Must match the password baked into autounattend.xml
// (and rendered into the autounattend ISO by build-answer-iso.sh).
// Wiped by sysprep at end of build.
winrm_password = "P@cker-Bu1ld!"
